# Proxy (supports both formats)
PROXY_SERVER=http://host:port
PROXY_USERNAME=user
PROXY_PASSWORD=pass

# Fallback proxy (used by company-page-http and company-page-browser)
PROXY_HOST_2=host2
PROXY_PORT_2=port2
PROXY_USERNAME_2=user2
PROXY_PASSWORD_2=pass2

# Browser
HEADLESS=true
BROWSER_WS_ENDPOINT=ws://...

# Server
PORT=3000
