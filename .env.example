# Proxy (supports both formats)
PROXY_SERVER=http://host:port
PROXY_USERNAME=user
PROXY_PASSWORD=pass

# Fallback proxy (used by company-page-browser)
PROXY_HOST_2=host2
PROXY_PORT_2=port2
PROXY_USERNAME_2=user2
PROXY_PASSWORD_2=pass2

# Fallback proxy pool for company-page-http — one is picked at random
# when the primary proxy fails or returns non-200. Each var holds a full URL.
FALLBACK_PROXY_1=http://user:pass@host:port
FALLBACK_PROXY_2=http://user:pass@host:port
FALLBACK_PROXY_3=http://user:pass@host:port
FALLBACK_PROXY_4=http://user:pass@host:port
FALLBACK_PROXY_5=http://user:pass@host:port

# Browser
HEADLESS=true
BROWSER_WS_ENDPOINT=ws://...

# Server
PORT=3000
